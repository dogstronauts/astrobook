{
    "name": "dogstronauts/astrobook",
    "type": "project",
    "description": "Forged in the legacy of Sirius, AstroBook guides the Dogstronauts in orchestrating their missions and managing galactic resources - A powerful system that centralizes event coordination and resource management across the galaxy",
    "keywords": [
        "api",
        "events",
        "management",
        "symfony",
        "api-platform"
    ],
    "homepage": "https://astrobook.dogstronauts.com",
    "license": "MIT",
    "authors": [
        {
            "name": "David Pelletier-Ulrich",
            "email": "d@mztrix.me",
            "homepage": "https://github.com/mztrix"
        },
        {
            "name": "AstroBook Community",
            "homepage": "https://astrobook.dogstronauts.com/contributors"
        }
    ],
    "support": {
        "email": "de25259ab1817bd62da981f2@dogstronauts.com",
        "issues": "https://github.com/dogstronauts/astrobook/issues",
        "source": "https://github.com/dogstronauts/astrobook"
    },
    "require": {
        "php": ">=8.4",
        "ext-ctype": "*",
        "ext-iconv": "*",
        "api-platform/doctrine-orm": "^4.2",
        "api-platform/symfony": "^4.2",
        "doctrine/dbal": "^4.4",
        "doctrine/doctrine-bundle": "^2.18",
        "doctrine/doctrine-migrations-bundle": "^3.7",
        "doctrine/orm": "^3.6",
        "gesdinet/jwt-refresh-token-bundle": "^1.5",
        "lexik/jwt-authentication-bundle": "^3.1",
        "nelmio/cors-bundle": "^2.6",
        "phpdocumentor/reflection-docblock": "^5.6",
        "phpstan/phpdoc-parser": "^2.3",
        "symfony/asset": "7.4.*",
        "symfony/console": "7.4.*",
        "symfony/dotenv": "7.4.*",
        "symfony/expression-language": "7.4.*",
        "symfony/flex": "^2.10",
        "symfony/framework-bundle": "7.4.*",
        "symfony/monolog-bundle": "^3.11",
        "symfony/property-access": "7.4.*",
        "symfony/property-info": "7.4.*",
        "symfony/runtime": "7.4.*",
        "symfony/security-bundle": "7.4.*",
        "symfony/serializer": "7.4.*",
        "symfony/twig-bundle": "7.4.*",
        "symfony/validator": "7.4.*",
        "symfony/yaml": "7.4.*",
        "symfony/translation": "7.4.*",
        "symfony/mailer": "7.4.*",
        "symfony/webhook": "7.4.*"
    },
    "replace": {
        "symfony/polyfill-ctype": "*",
        "symfony/polyfill-iconv": "*",
        "symfony/polyfill-php72": "*",
        "symfony/polyfill-php73": "*",
        "symfony/polyfill-php74": "*",
        "symfony/polyfill-php80": "*",
        "symfony/polyfill-php81": "*",
        "symfony/polyfill-php82": "*",
        "symfony/polyfill-php83": "*"
    },
    "require-dev": {
        "dama/doctrine-test-bundle": "^8.4",
        "doctrine/doctrine-fixtures-bundle": "^4.3",
        "friendsofphp/php-cs-fixer": "^3.92",
        "mtdowling/jmespath.php": "^2.8",
        "phpstan/phpstan": "^2.1",
        "phpstan/phpstan-doctrine": "^2.0",
        "phpstan/phpstan-symfony": "^2.0",
        "phpunit/phpunit": "^12.5",
        "rector/rector": "^2.2",
        "symfony/maker-bundle": "^1.65",
        "symfony/stopwatch": "7.4.*",
        "symfony/web-profiler-bundle": "7.4.*",
        "zenstruck/browser": "^1.9",
        "zenstruck/foundry": "^2.8"
    },
    "config": {
        "allow-plugins": {
            "php-http/discovery": true,
            "symfony/flex": true,
            "symfony/runtime": true
        },
        "bump-after-update": false,
        "sort-packages": false
    },
    "autoload": {
        "psr-4": {
            "Dogstronauts\\AstroBook\\": "src/",
            "Dogstronauts\\AstroBook\\Fixtures\\": "fixtures/",
            "Dogstronauts\\AstroBook\\DoctrineMigrations\\": "migrations/"
        }
    },
    "autoload-dev": {
        "psr-4": {
            "Dogstronauts\\AstroBook\\Tests\\": "tests/"
        }
    },
    "conflict": {
        "symfony/symfony": "*"
    },
    "extra": {
        "symfony": {
            "allow-contrib": true,
            "require": "7.4.*",
            "docker": true
        }
    },
    "scripts": {
        "export-doc": "docker run --rm -v $(pwd):/data -w /data phpdoc/phpdoc",
        "export-openapi-doc": "bin/console api:openapi:export > openapi.json",
        "php-cs-fixer": "vendor/bin/php-cs-fixer fix --config=.php-cs-fixer.dist.php",
        "rector": "php bin/rector",
        "tests": "php bin/phpunit --testdox",
        "fixtures": "php bin/console f:l -n",
        "auto-scripts": {
            "cache:clear": "symfony-cmd",
            "assets:install %PUBLIC_DIR%": "symfony-cmd"
        },
        "post-install-cmd": [
            "@auto-scripts"
        ],
        "post-update-cmd": [
            "@auto-scripts"
        ]
    },
    "minimum-stability": "stable"
}
